# SentDM — https://docs.sent.dm
# Copy to .env.local and fill in your values.

# API key from the Sent dashboard (x-api-key)
SENT_DM_API_KEY=f2d3daf1-c012-4483-bebe-bb2c52401130

# Your phone number in E.164 format — receives a text on each form submit
SENT_DM_NOTIFY_PHONE=+15865551234

# Optional: use a Sent template instead of free-form SMS text.
# Template variables expected: name, email, message
# SENT_DM_TEMPLATE_ID=
