# Admin dashboard — https://macombcode.com/admin
ADMIN_PASSWORD=

# Private Vercel Blob store (lead storage)
# From Vercel → Storage → your private Blob store → connect to project
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=
# Some Vercel examples name the store id like this instead:
# ADMIN_PASSWORD_STORE_ID=

# Local lead storage uses data/inquiries.json when Blob is not configured.

# Resend email — contact notify + booking confirmations
# RESEND_API_KEY=
# CONTACT_NOTIFY_EMAIL=austynjchalifour@yahoo.com
# CONTACT_FROM_EMAIL=Macomb Code <info@macombcode.com>

# SentDM SMS — currently disabled
# SENT_DM_API_KEY=
# SENT_DM_NOTIFY_PHONE=+15865551234
# SENT_DM_TEMPLATE_ID=

# Stripe — Website In A Day checkout (Managed Payments)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Optional on the client later; Checkout redirect uses the secret key on the server
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Endpoint URL: https://macombcode.com/api/stripe/webhook
# Subscribe to: checkout.session.completed
STRIPE_WEBHOOK_SECRET=
# Optional overrides (defaults live in data/offer.ts)
# STRIPE_WEBSITE_IN_A_DAY_PRICE_ID=price_1TwjJiAwj68vtnyzOj5ZNRAJ
# NEXT_PUBLIC_APP_URL=https://macombcode.com

