# Admin dashboard — https://macombcode.com/admin
ADMIN_PASSWORD=

# Production lead storage (Vercel Blob) — required on Vercel
# Vercel → Storage → Create Blob store → connect to this project
# That adds BLOB_READ_WRITE_TOKEN and/or BLOB_STORE_ID automatically.
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=
# Use "private" if your Blob store is private (default here is public)
# BLOB_ACCESS=public

# Local lead storage uses data/inquiries.json when Blob is not configured.

# Resend email — unused for contact submit
# RESEND_API_KEY=
